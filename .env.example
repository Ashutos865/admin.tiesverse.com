# Supabase — service key (NEVER expose to frontend)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-key-from-supabase-dashboard>

# Django
SECRET_KEY=your-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# AWS SES (transactional email). Leave creds blank to keep all email stubbed
# to the console. Each *_EMAIL_ENABLED flag must ALSO be True for real sending.
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=ap-south-1
SES_FROM_EMAIL=noreply@tiesverse.com
SES_CAREERS_FROM_EMAIL=careers@tiesverse.com

# Per-purpose email switches (default False until SES senders are verified)
ONBOARDING_EMAIL_ENABLED=False
OFFER_EMAIL_ENABLED=False
CERT_EMAIL_ENABLED=False
PASSWORD_RESET_EMAIL_ENABLED=False

# Public URLs
WEBSITE_URL=https://tiesverse.com
ADMIN_PORTAL_URL=http://localhost:5173
